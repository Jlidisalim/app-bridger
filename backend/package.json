{
  "name": "bridger-backend",
  "version": "1.0.0",
  "description": "Bridger API Server",
  "main": "dist/server.js",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"tsc --watch --preserveWatchOutput\" \"nodemon --watch dist --delay 1 dist/server.js\"",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^7.120.3",
    "axios": "^1.7.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^1.41.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "expo-server-sdk": "^3.15.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "form-data": "^4.0.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.11.20",
    "multer": "^1.4.5-lts.1",
    "sanitize-html": "^2.13.0",
    "socket.io": "^4.7.2",
    "stripe": "^14.9.0",
    "twilio": "^5.3.0",
    "uuid": "^9.0.1",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/sanitize-html": "^2.13.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
