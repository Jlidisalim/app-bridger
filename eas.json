{
  "cli": {
    "version": ">= 16.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://bridger-api.azurewebsites.net",
        "EXPO_PUBLIC_FACE_API_URL": "https://bridger-face.azurewebsites.net"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://bridger-api.azurewebsites.net",
        "EXPO_PUBLIC_FACE_API_URL": "https://bridger-face.azurewebsites.net"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
