@startuml
title Raffinement — Cas d'Utilisation « Créer un Trajet »

left to right direction
skinparam actorStyle awesome

actor "Voyageur" as Traveler

rectangle "Création d'un trajet (5 étapes)" {
  usecase "Étape 1 : Définir\nla route du trajet" as UC1
  usecase "Sélectionner ville\net pays de départ" as UC1a
  usecase "Sélectionner ville\net pays d'arrivée" as UC1b
  usecase "Choisir dates\ndépart et arrivée" as UC1c
  usecase "Étape 2 : Détails\ndu vol (optionnel)" as UC2
  usecase "Saisir numéro\nde vol" as UC2a
  usecase "Saisir compagnie\naérienne" as UC2b
  usecase "Étape 3 : Définir\nla capacité" as UC3
  usecase "Indiquer poids\ndisponible (kg)" as UC3a
  usecase "Indiquer taille max\nacceptée" as UC3b
  usecase "Étape 4 : Fixer\nle tarif" as UC4
  usecase "Définir prix\npar kg" as UC4a
  usecase "Voir commission\nplateforme (5%)" as UC4b
  usecase "Étape 5 : Réviser\net publier" as UC5
}

Traveler --> UC1
Traveler --> UC2
Traveler --> UC3
Traveler --> UC4
Traveler --> UC5

UC1 ..> UC1a : <<include>>
UC1 ..> UC1b : <<include>>
UC1 ..> UC1c : <<include>>

UC2 ..> UC2a : <<include>>
UC2 ..> UC2b : <<include>>

UC3 ..> UC3a : <<include>>
UC3 ..> UC3b : <<include>>

UC4 ..> UC4a : <<include>>
UC4 ..> UC4b : <<include>>

@enduml
