@startuml
title Raffinement — Cas d'Utilisation « Évaluation Post-Livraison »

left to right direction
skinparam actorStyle awesome

actor "Expéditeur" as Sender
actor "Voyageur" as Traveler

rectangle "Évaluation Post-Livraison" {
  usecase "Accéder à l'écran\nd'évaluation" as UC1
  usecase "Donner une note\n(1 à 5 étoiles)" as UC2
  usecase "Rédiger un commentaire\n(optionnel)" as UC3
  usecase "Soumettre l'évaluation" as UC4
  usecase "Mettre à jour le\nrating moyen du profil" as UC5
  usecase "Afficher l'avis sur\nle profil public" as UC6
  usecase "Ignorer l'évaluation" as UC7
}

Sender --> UC1
Traveler --> UC1

UC1 ..> UC2 : <<include>>
UC1 ..> UC3 : <<extend>>
UC2 ..> UC4 : <<include>>
UC4 ..> UC5 : <<include>>
UC4 ..> UC6 : <<include>>
UC1 ..> UC7 : <<extend>>

note right of UC1
  Déclenché automatiquement
  après un deal COMPLETED
  Les deux parties peuvent
  s'évaluer mutuellement
end note

note bottom of UC5
  rating = moyenne pondérée
  de toutes les évaluations
  reçues par l'utilisateur
end note

@enduml
